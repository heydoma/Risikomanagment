	doi = {10.1007/978-3-662-62336-7_4},
	abstract = {Künstliche Intelligenz ist ein Segen oder eine Bedrohung für den Menschen? Höchste Zeit, die Debatte zu versachlichen. Aktuell sieht es weder nach dem einen oder anderen aus, aber keiner kann in die Zukunft blicken. Sicher ist, dass Data Science, wie jede Technologie, auch für schlechte Dinge verwendet werden kann. Aktuell gibt aber vor allem die unbedachte Verwendung Anlass zur Sorge. Das fängt mit sauberen Daten und der korrekten Anwendung der statistischen Methoden an, die durch die heutige Publikationskultur eher wenig beachtet werden. Auch kommt man immer mehr dahinter, wie wichtig die vorsichtige Zusammenstellung eines Trainingsdatensätze ist, um Verzerrungen zu vermeiden. Neben dem Handwerkszeug sollen aber auch allgemeinere ethische Probleme, die zum Beispiel beim autonomes Fahren bedacht werden sollten, nicht unerwähnt bleiben.},
	pages = {77--106},
	booktitle = {Das Zeitalter der Daten: Was Sie über Grundlagen, Algorithmen und Anwendungen wissen sollten},
	publisher = {Springer},
	author = {Aust, Holger},
	editor = {Aust, Holger},
	urldate = {2026-04-19},
	date = {2021},
	langid = {german},
}

